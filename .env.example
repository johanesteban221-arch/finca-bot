# Copy to .env.local (local dev) or set these as Environment vars in Easypanel.
# NEVER commit real values — .env.local is gitignored.

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # legacy service_role JWT

# WhatsApp Cloud API (Meta) - app "Ganaderia"
WHATSAPP_PHONE_NUMBER_ID=000000000000000
WHATSAPP_TOKEN=EAA...                       # System User permanent token
WHATSAPP_VERIFY_TOKEN=choose-a-random-string  # must match the value set in Meta webhook

# Anthropic Claude (only used later for owner free-text queries / smart alerts)
# ANTHROPIC_API_KEY=sk-ant-...
